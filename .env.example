# LLM provider for optimizer explanation routes
LLM_PROVIDER=azure-openai
NEXT_PUBLIC_LLM_PROVIDER=azure-openai

# Azure OpenAI chat deployment for optimizer explanations
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4-1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional for local/dev if managed identity is not used
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Anthropic API key — optional when LLM_PROVIDER=anthropic
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional HMRC MCP HTTP bridge used by /api/optimizer-explain for live citations
HMRC_TAX_MCP_BASE_URL=http://localhost:8000

# Optional HMRC RAG corpus overrides used by /api/optimizer-explain
HMRC_RAG_DATABASE=hmrc-guidance
HMRC_RAG_CONTAINER=hmrc-chunks

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
# Feature flags
# Control which UI panels are enabled. These are baked into the Next.js bundle at
# Docker build time via --build-arg. Set as GitHub repo secrets to change without
# a code change — the workflow falls back to the defaults shown here if the secret
# is not set.
#
# NEXT_PUBLIC_OPTIMIZER_ENABLED — AI-enabled withdrawal optimizer panel in Step 4.
NEXT_PUBLIC_OPTIMIZER_ENABLED=true
# NEXT_PUBLIC_IHT_ADVANCED_ENABLED — IHT Outlook panel in Step 4 (estate projection,
# April 2027 pension delta, gifting capacity). Intended as a premium/paywall feature.
NEXT_PUBLIC_IHT_ADVANCED_ENABLED=false

# Cloudflare Turnstile (optional but recommended for AI endpoint)
# https://developers.cloudflare.com/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key

# Azure encrypted persistence
AZURE_COSMOSDB_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOSDB_DATABASE=later-life-planner
AZURE_COSMOSDB_CONTAINER=user-plans
# Optional: local/dev fallback if managed identity is not used
AZURE_COSMOSDB_KEY=your-cosmos-key
AZURE_KEY_VAULT_URL=https://your-key-vault.vault.azure.net/

# Azure credentials for local/server deployments that are not using managed identity
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Optional financial assumptions override
NEXT_PUBLIC_INVESTMENT_RETURN=4
NEXT_PUBLIC_DEFAULT_INFLATION=2.5
NEXT_PUBLIC_DEFAULT_LIFE_EXPECTANCY=95
