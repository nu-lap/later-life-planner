# Anthropic API key — required for AI features
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_OPTIMIZER_ENABLED=true

# Cloudflare Turnstile (optional but recommended for AI endpoint)
# https://developers.cloudflare.com/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key

# Azure encrypted persistence
AZURE_COSMOSDB_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOSDB_DATABASE=later-life-planner
AZURE_COSMOSDB_CONTAINER=user-plans
# Optional: local/dev fallback if managed identity is not used
AZURE_COSMOSDB_KEY=your-cosmos-key
AZURE_KEY_VAULT_URL=https://your-key-vault.vault.azure.net/

# Azure credentials for local/server deployments that are not using managed identity
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Optional financial assumptions override
NEXT_PUBLIC_INVESTMENT_RETURN=4
NEXT_PUBLIC_DEFAULT_INFLATION=2.5
NEXT_PUBLIC_DEFAULT_LIFE_EXPECTANCY=95
